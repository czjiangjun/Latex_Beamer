\\section{人工智能概述}

\\begin{frame}{学习目标}
\\begin{itemize}
    \\item 理解判别式与生成式AI的核心区别
    \\item 掌握机器学习三要素
    \\item 熟悉深度学习基础架构
    \\item 学会设计有效提示词
\\end{itemize}
\\end{frame}

\\begin{frame}{关键词}
\\begin{multicols}{2}
\\begin{itemize}
    \\item 判别式 AI
    \\item 生成式 AI
    \\item 机器学习
    \\item 深度学习
    \\item Transformer
    \\item 提示词工程
    \\item RAG
    \\item 微调
    \\item 函数调用
    \\item 智能体
\\end{itemize}
\\end{multicols}
\\end{frame}

\\begin{frame}{AI定义与分层}
\\begin{block}{强/弱/超人工智能}
\\begin{itemize}
    \\item 弱AI：专用于特定任务（如人脸识别）
    \\item 强AI：通用智能（尚未实现）
    \\item 超AI：超越人类智能（理论）
\\end{itemize}
\\end{block}
\\begin{block}{三大主义}
\\begin{itemize}
    \\item 符号主义：逻辑推理
    \\item 联结主义：神经网络
    \\item 行为主义：强化学习
\\end{itemize}
\\end{block}
\\end{frame}

\\begin{frame}{判别式 vs 生成式}
\\begin{figure}
\\centering
\\framebox{\\parbox{0.9\\textwidth}{\\centering 判别式：学习类别边界 \\\\ 生成式：学习数据分布}}
\\caption{概念对比图}
\\end{figure}
\\begin{itemize}
    \\item 判别式：分类、回归
    \\item 生成式：创造新样本
\\end{itemize}
\\end{frame}

\\begin{frame}{机器学习三要素}
\\begin{itemize}
    \\item \\textbf{数据}：特征、标签
    \\item \\textbf{模型}：线性回归、决策树、神经网络
    \\item \\textbf{算法}：梯度下降、反向传播
\\end{itemize}
\\begin{center}
\\framebox{\\parbox{0.5\\textwidth}{数据 + 模型 + 算法 = 学习系统}}
\\end{center}
\\end{frame}

\\begin{frame}{监督/无监督/强化学习}
\\begin{tabular}{p{0.3\\textwidth}p{0.6\\textwidth}}
\\toprule
类型 & 说明 \\\\
\\midrule
监督学习 & 有标签，分类/回归 \\\\
无监督学习 & 无标签，聚类/降维 \\\\
强化学习 & 奖励信号，策略优化 \\\\
\\bottomrule
\\end{tabular}
\\end{frame}

\\begin{frame}{经典算法1：线性回归}
\\begin{itemize}
    \\item 建模线性关系 \\(y = wx + b\\)
    \\item 损失函数：均方误差
    \\item 优化：最小二乘法 / 梯度下降
\\end{itemize}
\\end{frame}

\\begin{frame}{经典算法2：决策树}
\\begin{itemize}
    \\item 树状结构，可解释性强
    \\item 分裂准则：信息增益、基尼系数
    \\item 集成方法：随机森林、XGBoost
\\end{itemize}
\\end{frame}

\\begin{frame}{经典算法3：SVM}
\\begin{itemize}
    \\item 最大化分类间隔
    \\item 核技巧处理非线性
    \\item 支持向量决定决策边界
\\end{itemize}
\\end{frame}

\\begin{frame}{经典算法4：KNN}
\\begin{itemize}
    \\item 懒惰学习，无显式训练
    \\item 距离度量（欧氏、曼哈顿）
    \\item 需要k值选择
\\end{itemize}
\\end{frame}

\\begin{frame}{深度学习兴起}
\\begin{itemize}
    \\item 神经网络基础：神经元、激活函数（ReLU, Sigmoid）
    \\item 多层结构自动提取特征
    \\item 大数据+GPU推动爆发
\\end{itemize}
\\end{frame}

\\begin{frame}{CNN：卷积神经网络}
\\begin{itemize}
    \\item 卷积层：提取局部特征
    \\item 池化层：降维、平移不变性
    \\item 感受野：逐层扩大
    \\item 应用：图像分类、目标检测
\\end{itemize}
\\end{frame}

\\begin{frame}{RNN/LSTM}
\\begin{itemize}
    \\item 循环神经网络处理序列
    \\item 梯度消失/爆炸问题
    \\item LSTM引入门控机制（输入门、遗忘门、输出门）
\\end{itemize}
\\end{frame}

\\begin{frame}{生成式AI核心}
\\begin{itemize}
    \\item 学习联合分布 \\(P(X,Y)\\) 或 \\(P(X)\\)
    \\item 采样生成新数据
    \\item 典型模型：VAE、GAN、扩散模型、自回归模型
\\end{itemize}
\\end{frame}

\\begin{frame}{Transformer架构概览}
\\begin{itemize}
    \\item 自注意力机制（Self-Attention）
    \\item 多头注意力（Multi-Head）
    \\item 位置编码（Positional Encoding）
    \\item Encoder-Decoder结构
\\end{itemize}
\\end{frame}

\\begin{frame}{Transformer详解1：自注意力}
\\[
\\text{Attention}(Q,K,V) = \\text{softmax}\\left(\\frac{QK^T}{\\sqrt{d_k}}\\right)V
\\]
\\begin{itemize}
    \\item Q：查询，K：键，V：值
    \\item 缩放点积注意力
    \\item 捕获长距离依赖
\\end{itemize}
\\end{frame}

\\begin{frame}{Transformer详解2：残差与归一化}
\\begin{itemize}
    \\item 残差连接：缓解梯度消失
    \\item 层归一化（LayerNorm）：稳定训练
    \\item 前馈网络（FFN）：非线性变换
\\end{itemize}
\\end{frame}

\\begin{frame}{提示词工程基础}
\\begin{block}{提示词要素}
\\begin{itemize}
    \\item 角色扮演
    \\item 明确任务
    \\item 约束条件
    \\item 输出格式
\\end{itemize}
\\end{block}
\\end{frame}

\\begin{frame}{提示词技巧}
\\begin{itemize}
    \\item 零样本（Zero-shot）：直接提问
    \\item 少样本（Few-shot）：给示例
    \\item 思维链（Chain-of-Thought）：逐步推理
    \\item 思维树（Tree-of-Thoughts）：探索多条路径
\\end{itemize}
\\end{frame}

